generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ImportStatus {
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum DocumentType {
  CPF
  CNPJ
}

enum ProtestStatus {
  IMPORTADO
  AGUARDANDO_ANALISE
  ENVIADO_CARTORIO
  INTIMADO
  AGUARDANDO_PAGAMENTO
  PAGO
  PROTESTADO
  SUSTADO
  RETIRADO
  CANCELADO
  DEVOLVIDO
  PENDENTE_BOLETO
  PENDENTE_PAGAMENTO
  PENDENTE_RETORNO
  ERRO_IMPORTACAO
}

enum PaymentStatus {
  PENDENTE
  INFORMADO
  CONFIRMADO
  CANCELADO
}

enum AttachmentType {
  BOLETO
  COMPROVANTE
  DOCUMENTO
  OUTRO
}

model User {
  id              String              @id @default(uuid())
  name            String
  email           String              @unique
  passwordHash    String
  role            UserRole            @default(EMPLOYEE)
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  importBatches   ImportBatch[]
  histories       ProtestHistory[]
  attachments     ProtestAttachment[]

  @@index([role])
}

model ImportBatch {
  id             String        @id @default(uuid())
  fileName       String
  fileType       String
  importedById   String
  totalRecords   Int           @default(0)
  validRecords   Int           @default(0)
  invalidRecords Int           @default(0)
  status         ImportStatus  @default(PROCESSING)
  createdAt      DateTime      @default(now())
  importedBy     User          @relation(fields: [importedById], references: [id], onDelete: Restrict)
  errors         ImportError[]
  protests       Protest[]

  @@index([status])
  @@index([createdAt])
  @@index([importedById])
}

model ImportError {
  id            String      @id @default(uuid())
  importBatchId String
  lineNumber    Int
  field         String?
  message       String
  rawContent    String?
  createdAt     DateTime    @default(now())
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
  @@index([lineNumber])
}

model Creditor {
  id           String       @id @default(uuid())
  name         String
  document     String
  documentType DocumentType
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  protests     Protest[]

  @@unique([document, documentType])
  @@index([name])
  @@index([document])
}

model Debtor {
  id           String       @id @default(uuid())
  name         String
  document     String
  documentType DocumentType
  address      String?
  city         String?
  state        String?
  zipCode      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  protests     Protest[]

  @@unique([document, documentType])
  @@index([name])
  @@index([document])
}

model Protest {
  id               String              @id @default(uuid())
  protocol         String              @unique
  titleNumber      String
  debtorId         String
  creditorId       String
  importBatchId    String?
  amount           Decimal             @db.Decimal(12, 2)
  dueDate          DateTime
  presentationDate DateTime
  status           ProtestStatus       @default(IMPORTADO)
  paymentStatus    PaymentStatus       @default(PENDENTE)
  hasBoleto        Boolean             @default(false)
  boletoDueDate    DateTime?
  boletoAmount     Decimal?            @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  debtor           Debtor              @relation(fields: [debtorId], references: [id], onDelete: Restrict)
  creditor         Creditor            @relation(fields: [creditorId], references: [id], onDelete: Restrict)
  importBatch      ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  attachments      ProtestAttachment[]
  histories        ProtestHistory[]
  payments         PaymentInfo[]

  @@index([protocol])
  @@index([titleNumber])
  @@index([status])
  @@index([paymentStatus])
  @@index([dueDate])
  @@index([presentationDate])
  @@index([debtorId])
  @@index([creditorId])
  @@index([importBatchId])
}

model ProtestAttachment {
  id             String         @id @default(uuid())
  protestId      String
  fileName       String
  fileUrl        String
  fileType       String
  attachmentType AttachmentType @default(OUTRO)
  uploadedById   String
  createdAt      DateTime       @default(now())
  protest        Protest        @relation(fields: [protestId], references: [id], onDelete: Cascade)
  uploadedBy     User           @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([protestId])
  @@index([uploadedById])
  @@index([attachmentType])
}

model ProtestHistory {
  id          String   @id @default(uuid())
  protestId   String
  userId      String
  action      String
  oldValue    String?
  newValue    String?
  description String?
  createdAt   DateTime @default(now())
  protest     Protest  @relation(fields: [protestId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([protestId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model PaymentInfo {
  id            String        @id @default(uuid())
  protestId     String
  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime?
  paymentMethod String?
  status        PaymentStatus @default(PENDENTE)
  notes         String?
  createdAt     DateTime      @default(now())
  protest       Protest       @relation(fields: [protestId], references: [id], onDelete: Cascade)

  @@index([protestId])
  @@index([status])
  @@index([paymentDate])
}
